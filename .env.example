# ============================================
# CamelliaLetter Web 환경 변수
# ============================================

# --------------------------------------------
# GitHub Packages (필수 - Vercel 배포 시 필요)
# --------------------------------------------

# GitHub Personal Access Token (packages:read 권한 필요)
# @camellia-letter/shared-types 패키지 설치를 위해 필수
# 발급: https://github.com/settings/tokens (Classic Token > read:packages 권한)
NPM_TOKEN=your-github-personal-access-token

# --------------------------------------------
# 필수 환경 변수
# --------------------------------------------

# API 서버 URL
NEXT_PUBLIC_API_URL=http://localhost:4002
# 프로덕션 예시: NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# 현재 웹 앱 기본 URL
NEXT_PUBLIC_BASE_URL=http://localhost:4000
# 프로덕션 예시: NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# 관리자 대시보드 URL
NEXT_PUBLIC_ADMIN_URL=http://localhost:4001
# 프로덕션 예시: NEXT_PUBLIC_ADMIN_URL=https://admin.yourdomain.com

# Kakao Maps API JavaScript 키
# 발급: https://developers.kakao.com/console/app
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key

# Kakao 커스텀 템플릿 ID (선택 - 카카오톡 공유하기 커스텀 템플릿)
# 발급: https://developers.kakao.com/console/app > 메시지 > 메시지 템플릿
NEXT_PUBLIC_KAKAO_TEMPLATE_ID=your_template_id

# --------------------------------------------
# Database (필수 - NextAuth Prisma Adapter)
# --------------------------------------------

# 데이터베이스 연결 URL (PostgreSQL)
# 발급: https://neon.tech 또는 기타 PostgreSQL 제공업체
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# --------------------------------------------
# NextAuth.js (필수)
# --------------------------------------------

# NextAuth 기본 URL (NEXT_PUBLIC_BASE_URL과 동일)
NEXTAUTH_URL=http://localhost:4000
# 프로덕션 예시: NEXTAUTH_URL=https://yourdomain.com

# NextAuth 암호화 키 (프로덕션에서 반드시 변경!)
# 생성 방법: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# --------------------------------------------
# OAuth 설정 (선택 - 사용할 Provider만 설정)
# --------------------------------------------

# Google OAuth (선택)
# 발급: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Kakao OAuth (선택)
# 발급: https://developers.kakao.com/console/app
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# Naver OAuth (선택)
# 발급: https://developers.naver.com/apps
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# --------------------------------------------
# 참고
# --------------------------------------------
# OAuth Provider를 사용하지 않는 경우 해당 변수를 삭제하거나 빈 값으로 둘 수 있습니다.
# NextAuth는 설정된 Provider만 활성화합니다.
